# Path to your local Antigravity/Cursor auth database on the host machine.
#
# macOS (Antigravity):
# AUTH_DB_HOST_PATH=~/Library/Application Support/Antigravity/User/globalStorage/state.vscdb
#
# Linux (Cursor):
# AUTH_DB_HOST_PATH=~/.config/Cursor/User/globalStorage/state.vscdb
#
AUTH_DB_HOST_PATH=

# Optional: host port mapped to the proxy (default: 3000)
# PROXY_PORT=3000
