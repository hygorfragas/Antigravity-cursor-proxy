# Path to your local Antigravity/Cursor auth database on the host machine.
#
# macOS (Antigravity):
# AUTH_DB_HOST_PATH=~/Library/Application Support/Antigravity/User/globalStorage/state.vscdb
#
# Linux (Cursor):
# AUTH_DB_HOST_PATH=~/.config/Cursor/User/globalStorage/state.vscdb
#
AUTH_DB_HOST_PATH=

# Host port exposed for your cloudflared connector to reach the container
# Example: cloudflared ingress -> http://IP_DA_SUA_MAQUINA:3010
PROXY_HOST_PORT=3010

# Public HTTPS URL configured in your cloudflared connector (without /v1)
PUBLIC_BASE_URL=https://antigravity.flowkaze.com.br

# Local development only (npm start uses quick tunnel by default)
# ENABLE_QUICK_TUNNEL=true
